# GitHub/GitLab API Tokens
# Get token at https://github.com/settings/tokens (for GitHub)
# or https://gitlab.com/-/user_settings/personal_access_tokens (for GitLab)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter API Key
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM model (OpenRouter format)
LLM_MODEL=google/gemini-2.5-flash-lite
LLM_BUDGET_ENABLED=1
LLM_TENANT_ID=default
LLM_MAX_PROMPT_CHARS=30000
LLM_MAX_EST_PROMPT_TOKENS=8000
LLM_DAILY_MAX_REQUESTS=400
LLM_DAILY_MAX_EST_TOKENS=1200000

# Telegram bot token (from @BotFather)
BOT_TOKEN=123456:ABC-DEF...

# SQLite database file path
DB_PATH=bot.db
# Optional PostgreSQL DSN (target architecture):
# Example: postgresql://autochecker:secret@localhost:5432/autochecker
DATABASE_URL=
DEFAULT_TENANT_ID=default

# Comma-separated list of active labs shown to students
ACTIVE_LABS=lab-01

# Max check attempts per task per student
MAX_ATTEMPTS_PER_TASK=12

# Dashboard password (leave empty to disable auth)
DASHBOARD_PASSWORD=
