# ── v2 API (api/app.py) ───────────────────────────────────────────────────────

# PostgreSQL (required)
DATABASE_URL=postgresql://user:password@localhost:5432/autochecker

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=72

# LLM provider: openai | anthropic | google
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=sk-...
LLM_BASE_URL=          # optional: override base URL (e.g. for Qwen-compatible endpoint)

# Telegram bot token (for push notifications to students)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# GitHub (optional — higher API rate limits)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# ── Legacy / original autochecker vars (kept for old bot/relay) ───────────────
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BOT_TOKEN=123456:ABC-DEF...
ACTIVE_LABS=lab-01
MAX_ATTEMPTS_PER_TASK=12
DASHBOARD_PASSWORD=
